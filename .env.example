DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require
NEON_AUTH_BASE_URL=https://<tu-auth-endpoint-neon>
NEON_AUTH_JWKS_URL=https://<tu-jwks-url-neon>
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token_with_analytics_read
CLOUDFLARE_HARD_LIMIT_ENABLED=true
CLOUDFLARE_HARD_LIMIT_PERCENT=99
CLOUDFLARE_HARD_LIMIT_FAIL_CLOSED=true
CLOUDFLARE_USAGE_CACHE_MS=60000
TURN_KEY_ID=your_cloudflare_turn_token_id
TURN_KEY_API_TOKEN=your_cloudflare_turn_api_token
TURN_TTL_SECONDS=86400
# Optional fallback (if not using Cloudflare dynamic credentials):
# TURN_URL=turn:example.com:3478?transport=udp
# TURN_USERNAME=your_turn_username
# TURN_CREDENTIAL=your_turn_credential
